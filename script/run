#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

if [ ! -x "$PROJECT_ROOT/.venv/bin/python3" ]; then
    echo "❌ Error: Virtual environment missing."
    exit 1
fi

cd "$PROJECT_ROOT"
exec .venv/bin/python3 wyoming_onnx_asr.py "$@"