#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python3"

# ==========================================================
# SAFETY CHECK
# ==========================================================
if [ ! -x "$VENV_PYTHON" ]; then
    echo "❌ Error: Virtual environment not found. Run setup first."
    exit 1
fi

# ==========================================================
# DYNAMIC CUDA/CUDNN WHEEL PATH INJECTION (CUDA 12 & 13 Support)
# ==========================================================
# Find the exact python site-packages path inside this virtual environment
PYTHON_VERSION=$("$VENV_PYTHON" -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}")')
SITE_PACKAGES="$PROJECT_ROOT/.venv/lib/${PYTHON_VERSION}/site-packages"

# 1. Discover CUDNN path (works for both nvidia_cudnn_cu12 and nvidia_cudnn_cu13)
CUDNN_LIB_DIR=$(find "$SITE_PACKAGES/nvidia" -type d -path "*/cudnn/lib" 2>/dev/null | head -n 1)

# 2. Discover CUDA Runtime path (works for both nvidia_cuda_runtime_cu12 and the new nvidia/cuda_runtime)
CUDA_LIB_DIR=$(find "$SITE_PACKAGES/nvidia" -type d -path "*/cuda_runtime/lib" 2>/dev/null | head -n 1)

# Inject discovered paths into LD_LIBRARY_PATH if they exist
if [ -n "$CUDA_LIB_DIR" ] && [ -n "$CUDNN_LIB_DIR" ]; then
    export LD_LIBRARY_PATH="$CUDA_LIB_DIR:$CUDNN_LIB_DIR:${LD_LIBRARY_PATH}"
    DETECTED_GPU_ENV="Python Bundled Wheels"
else
    DETECTED_GPU_ENV="System / Fallback"
fi

# ==========================================================
# HA OPTIMIZED DEFAULTS
# ==========================================================
# Only set if user didn't override
DEFAULT_ENDPOINT_MS=500

if [[ " $* " != *"--endpoint-ms"* ]]; then
    EXTRA_ARGS+=(--endpoint-ms "$DEFAULT_ENDPOINT_MS")
fi

# ==========================================================
# ONNX / CPU THREADING (LOW LATENCY MODE)
# ==========================================================
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1

# ORT consistency with Python config
export ORT_LOGGING_LEVEL=3
export ORT_DISABLE_THREAD_AFFINITY=1
export ORT_NUM_THREADS=1

# ==========================================================
# CUDA / GPU STABILITY
# ==========================================================
export CUDA_VISIBLE_DEVICES=0

# Reduces startup latency + memory spikes
export CUDA_MODULE_LOADING=LAZY

# Optional: reduce contention with other GPU workloads (like Ollama)
# Uncomment if you see latency spikes
# export CUDA_DEVICE_MAX_CONNECTIONS=1

# ==========================================================
# HUGGINGFACE / FS STABILITY
# ==========================================================
export HF_HUB_DISABLE_SYMLINKS=1

# ==========================================================
# START
# ==========================================================
echo "🚀 Starting Wyoming ONNX ASR..."
echo "📁 Project: $PROJECT_ROOT"

echo "⚙️ Runtime config:"
echo "   - Threads: $ORT_NUM_THREADS"
echo "   - GPU: ${CUDA_VISIBLE_DEVICES:-CPU} (${DETECTED_GPU_ENV})"
echo "   - Endpoint: ${DEFAULT_ENDPOINT_MS}ms (default if not overridden)"

cd "$PROJECT_ROOT"

exec "$VENV_PYTHON" wyoming_onnx_asr.py "${EXTRA_ARGS[@]}" "$@"