#!/usr/bin/env bash
set -e

echo "--- Wyoming ONNX ASR Environment Setup ---"

# --- System Info ---
DISTRO=$(. /etc/os-release; echo "$ID")
VERSION_ID=$(. /etc/os-release; echo "$VERSION_ID" | tr -d '.')

echo "📦 Installing system dependencies..."
sudo apt update
# Notice we dropped gpg, keyring, and nvidia apt repos entirely
sudo apt install -y libsndfile1 python3-venv wget curl

# --- GPU Detection (Driver Check Only) ---
GPU_INSTALL=false

if command -v nvidia-smi &> /dev/null; then
    if nvidia-smi &> /dev/null; then
        echo "🚀 NVIDIA GPU Detected via Driver!"
        # Grab the maximum supported CUDA version from nvidia-smi
        MAX_CUDA=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader | awk -F. '{if ($1 >= 550) print "13"; else print "12"}')
        echo "💡 Driver supports CUDA ${MAX_CUDA} ecosystem."
        GPU_INSTALL=true
    fi
fi

if [ "$GPU_INSTALL" = false ]; then
    echo "🐌 No NVIDIA GPU driver active → CPU-only mode"
fi

# --- Virtual Environment ---
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_ROOT/.venv"

echo "🐍 Creating virtual environment at $VENV_DIR..."
python3 -m venv "$VENV_DIR"

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"

pip install --upgrade pip wheel setuptools

# --- Install dependencies ---
if [ "$GPU_INSTALL" = true ]; then
    echo "⚙️ Installing GPU requirements..."
    if [ "$MAX_CUDA" = "13" ]; then
        echo "⚡ Using CUDA 13 Requirements Target"
        pip install -r "$PROJECT_ROOT/requirements-gpu-cuda13.txt"
    else
        echo "⚡ Using CUDA 12 Requirements Target"
        pip install -r "$PROJECT_ROOT/requirements-gpu-cuda13.txt"
    fi
else
    echo "⚙️ Installing CPU requirements..."
    pip install -r "$PROJECT_ROOT/requirements-cpu.txt"
fi

# --- Runtime consistency (Updated for modular execution) ---
echo "🧠 Writing runtime environment defaults..."

cat > "$PROJECT_ROOT/.env.runtime" <<EOF
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
ORT_LOGGING_LEVEL=3
ORT_DISABLE_THREAD_AFFINITY=1
ORT_NUM_THREADS=1
CUDA_VISIBLE_DEVICES=0
HF_HUB_DISABLE_SYMLINKS=1
EOF

# --- Permissions ---
chmod +x "$SCRIPT_DIR/run" 2>/dev/null || true
chmod +x "$SCRIPT_DIR/install-service" 2>/dev/null || true

echo "--------------------------------------------------"
echo "✅ Setup complete!"
echo "👉 Run: ./script/run"
echo "--------------------------------------------------"