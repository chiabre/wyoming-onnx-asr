#!/usr/bin/env bash
set -e

echo "--- Wyoming ONNX ASR Environment Setup ---"

# --- System Info ---
DISTRO=$(. /etc/os-release; echo "$ID")
VERSION_ID=$(. /etc/os-release; echo "$VERSION_ID" | tr -d '.')
ARCH="x86_64"

echo "📦 Installing system dependencies..."
sudo apt update
sudo apt install -y libsndfile1 python3-venv wget gnupg2 curl

# --- GPU Detection ---
GPU_INSTALL=false

if command -v nvidia-smi &> /dev/null; then
    if nvidia-smi &> /dev/null; then
        echo "🚀 NVIDIA GPU detected. Installing CUDA 12.6..."

        case "$DISTRO" in
            debian) REPO_NAME="debian${VERSION_ID}" ;;
            ubuntu) REPO_NAME="ubuntu${VERSION_ID}" ;;
            *)
                echo "❌ Unsupported distro: $DISTRO"
                exit 1
                ;;
        esac

        wget -q "https://developer.download.nvidia.com/compute/cuda/repos/${REPO_NAME}/${ARCH}/cuda-keyring_1.1-1_all.deb" -O cuda-keyring.deb
        sudo dpkg -i cuda-keyring.deb
        rm cuda-keyring.deb

        sudo apt update
        sudo apt install -y cuda-toolkit-12-6 cudnn9-cuda-12

        GPU_INSTALL=true
    fi
fi

if [ "$GPU_INSTALL" = false ]; then
    echo "🐌 No NVIDIA GPU detected → CPU-only mode"
fi

# --- Virtual Environment ---
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_ROOT/.venv"

echo "🐍 Creating virtual environment at $VENV_DIR..."
python3 -m venv "$VENV_DIR"

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"

pip install --upgrade pip wheel setuptools

# --- Install dependencies ---
if [ "$GPU_INSTALL" = true ]; then
    echo "⚙️ Installing GPU requirements..."
    pip install -r "$PROJECT_ROOT/requirements-gpu.txt"
else
    echo "⚙️ Installing CPU requirements..."
    pip install -r "$PROJECT_ROOT/requirements-cpu.txt"
fi

# --- Runtime consistency (IMPORTANT) ---
echo "🧠 Writing runtime environment defaults..."

cat > "$PROJECT_ROOT/.env.runtime" <<EOF
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
ORT_LOGGING_LEVEL=3
ORT_DISABLE_THREAD_AFFINITY=1
ORT_NUM_THREADS=1
CUDA_VISIBLE_DEVICES=0
HF_HUB_DISABLE_SYMLINKS=1
EOF

# --- Permissions ---
chmod +x "$SCRIPT_DIR/run" 2>/dev/null || true
chmod +x "$SCRIPT_DIR/install-service" 2>/dev/null || true

echo "--------------------------------------------------"
echo "✅ Setup complete!"
echo "👉 Run: ./script/run"
echo "--------------------------------------------------"
