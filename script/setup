#!/usr/bin/env bash
set -e

echo "--- Wyoming ONNX ASR Environment Setup (CUDA 13 + CPU) ---"

# --- System Info ---
DISTRO=$(. /etc/os-release; echo "$ID")
VERSION_ID=$(. /etc/os-release; echo "$VERSION_ID" | tr -d '.')
ARCH="x86_64"

echo "📦 Installing system dependencies..."
sudo apt update
sudo apt install -y libsndfile1 python3-venv python3-dev build-essential wget gnupg2 curl

# --- GPU Detection ---
GPU_INSTALL=false

if command -v nvidia-smi &> /dev/null && nvidia-smi &> /dev/null; then
    echo "⚡ NVIDIA GPU detected. Provisioning CUDA 13 stack..."
    
    case "$DISTRO" in
        debian) REPO_NAME="debian${VERSION_ID}" ;;
        ubuntu) REPO_NAME="ubuntu${VERSION_ID}" ;;
        *)
            echo "❌ Unsupported distro: $DISTRO"
            exit 1
            ;;
    esac

    # Register NVIDIA repository
    wget -q "https://developer.download.nvidia.com/compute/cuda/repos/${REPO_NAME}/${ARCH}/cuda-keyring_1.1-1_all.deb" -O cuda-keyring.deb
    sudo dpkg -i cuda-keyring.deb
    rm cuda-keyring.deb
    
    sudo apt update
    sudo apt install -y cuda-toolkit-13-1 cudnn9-cuda-13
    GPU_INSTALL=true
fi

if [ "$GPU_INSTALL" = false ]; then
    echo "🐌 No NVIDIA GPU detected → CPU-only mode"
fi

# --- Virtual Environment ---
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$PROJECT_ROOT/.venv"

echo "🐍 Creating virtual environment at $VENV_DIR..."
python3 -m venv "$VENV_DIR"

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"
pip install --upgrade pip wheel setuptools

# --- Install Dependencies ---
if [ "$GPU_INSTALL" = true ]; then
    echo "⚙️ Installing GPU requirements (CUDA 13 Nightly)..."
    pip install --pre -r "$PROJECT_ROOT/requirements-gpu.txt"
else
    echo "⚙️ Installing CPU requirements..."
    pip install -r "$PROJECT_ROOT/requirements-cpu.txt"
fi

# --- Permissions ---
chmod +x "$SCRIPT_DIR/run" 2>/dev/null || true
chmod +x "$SCRIPT_DIR/install-service" 2>/dev/null || true

echo "--------------------------------------------------"
echo "✅ Setup complete!"
echo "👉 Run your service installer to finish deployment."
echo "--------------------------------------------------"